{
    "name": "pulse-app",
    "version": "0.1.0",
    "private": true,
    "description": "The Pulse application \u2014 planning boards over GitHub",
    "type": "module",
    "scripts": {
        "dev": "node server.mjs",
        "build": "vite build --app",
        "build:cloudflare": "vite build --app -c vite.config.cloudflare.ts",
        "start": "cross-env NODE_ENV=production node --conditions production server.mjs",
        "smoke": "node smoke.mjs",
        "smoke:cf": "node smoke.mjs --cf"
    },
    "dependencies": {
        "sigx": "catalog:",
        "@sigx/reactivity": "catalog:",
        "@sigx/runtime-core": "catalog:",
        "@sigx/runtime-dom": "catalog:",
        "@sigx/server": "catalog:",
        "@sigx/server-renderer": "catalog:",
        "@sigx/cache": "catalog:",
        "@sigx/router": "^0.10.0",
        "@sigx/store": "^0.11.0",
        "@fontsource-variable/hanken-grotesk": "^5.3.0",
        "@fontsource-variable/jetbrains-mono": "^5.3.0",
        "tailwindcss": "^4.2.4",
        "express": "^5.2.1",
        "valibot": "^1.4.2",
        "@pulse/github": "workspace:*",
        "@pulse/auth": "workspace:*",
        "@pulse/db": "workspace:*"
    },
    "devDependencies": {
        "@sigx/cloudflare": "catalog:",
        "@sigx/vite": "catalog:",
        "@tailwindcss/vite": "^4.2.4",
        "@types/express": "^5.0.6",
        "@types/node": "^26.1.1",
        "cross-env": "^10.1.0",
        "typescript": "^7.0.2",
        "vite": "^8.1.4",
        "wrangler": "^4.114.0"
    }
}
