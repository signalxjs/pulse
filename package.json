{
    "name": "pulse",
    "version": "0.1.0",
    "private": true,
    "description": "Pulse — Linear-style planning on top of GitHub, built on SignalX",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "https://github.com/signalxjs/pulse.git"
    },
    "author": "Andreas Ekdahl <andy@ekdahls.net>",
    "license": "MIT",
    "packageManager": "pnpm@10.33.4",
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "dev": "pnpm --filter pulse-app dev",
        "build": "pnpm --filter pulse-app build",
        "start": "pnpm --filter pulse-app start",
        "smoke": "pnpm --filter pulse-app smoke",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "lint": "oxlint --deny-warnings app/src packages/*/src",
        "wt": "node scripts/worktree.mjs",
        "branch-protection": "node scripts/apply-branch-protection.mjs"
    },
    "pnpm": {
        "overrides": {
            "@sigx/cache>@sigx/reactivity": "0.10.0",
            "@sigx/cache>@sigx/runtime-core": "0.10.0"
        },
        "//": "TEMPORARY: @sigx/cache@0.10.0 shipped with workspace:^ specifiers (signalxjs/core#301); drop when the republish lands."
    },
    "devDependencies": {
        "@types/node": "^26.1.1",
        "happy-dom": "^20.10.6",
        "oxlint": "^1.41.0",
        "playwright": "^1.61.1",
        "typescript": "^7.0.2",
        "vitest": "^4.1.10"
    }
}
