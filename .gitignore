# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
dist-cf/
build/
docs/dist/

# Wrangler local state (dev server / local D1)
.wrangler/
*.d.ts
*.d.ts.map
*.js
*.js.map

# Keep specific JS files
!vite.config.js
!*.config.js

# Source is source: Pulse has JSDoc-typed JS packages (they run under the
# no-transpiler server) and ambient declarations — only ignore built output.
# (These negations must come AFTER the *.js/*.d.ts patterns to win.)
!app/src/env.d.ts
!app/src/env.cloudflare.d.ts
!packages/*/src/**
!packages/*/scripts/**
!packages/*/fixtures/**
!examples/*.js
!scripts/*.js

# TypeScript cache
*.tsbuildinfo

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Testing
coverage/

# Misc
.cache/
.temp/
.tmp/
