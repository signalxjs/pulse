{
    "name": "@pulse/github",
    "version": "0.1.0",
    "private": true,
    "description": "Pulse's GitHub API client — live + fixtures adapters behind one interface, ETag/conditional-request caching (server-only)",
    "type": "module",
    "main": "./src/index.js",
    "types": "./src/index.d.ts",
    "exports": {
        ".": {
            "types": "./src/index.d.ts",
            "default": "./src/index.js"
        },
        "./fixtures": {
            "types": "./src/fixtures.d.ts",
            "default": "./src/fixtures.js"
        },
        "./node": {
            "types": "./src/node.d.ts",
            "default": "./src/etag-cache.js"
        }
    },
    "engines": {
        "node": ">=24"
    }
}
