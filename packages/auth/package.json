{
    "name": "@pulse/auth",
    "version": "0.1.0",
    "private": true,
    "description": "Pulse's GitHub auth \u2014 OAuth web flow + PAT fallback, encrypted-token sessions in node:sqlite, signed HttpOnly cookies (server-only)",
    "type": "module",
    "main": "./src/index.js",
    "types": "./src/index.d.ts",
    "exports": {
        ".": {
            "types": "./src/index.d.ts",
            "default": "./src/index.js"
        }
    },
    "engines": {
        "node": ">=24"
    },
    "dependencies": {
        "express": "^5.2.1",
        "@pulse/github": "workspace:*"
    },
    "devDependencies": {
        "@types/express": "^5.0.6"
    }
}
